<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Create the POS Taxable Sales product -->
        <record id="product_pos_taxable_sales" model="product.product">
            <field name="name">POS Taxable Sales</field>
            <field name="default_code">TAXABLE-SALES</field>
            <field name="type">service</field>
            <field name="categ_id" ref="product.product_category_all"/>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
            <field name="list_price">0.00</field>
            <field name="description">Product for consolidated taxable sales in POS</field>
        </record>

        <!-- Create the POS Non-Taxable Sales product -->
        <record id="product_pos_non_taxable_sales" model="product.product">
            <field name="name">POS Non-Taxable Sales</field>
            <field name="default_code">NON-TAXABLE-SALES</field>
            <field name="type">service</field>
            <field name="categ_id" ref="product.product_category_all"/>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
            <field name="list_price">0.00</field>
            <field name="description">Product for consolidated non-taxable sales in POS</field>
            <!-- Remove all taxes from this product -->
            <field name="taxes_id" eval="[(5, 0, 0)]"/>
        </record>
    </data>
</odoo>