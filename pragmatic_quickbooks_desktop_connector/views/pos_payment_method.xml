<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_pos_payment_method_form_inherit_quickbooks" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.quickbooks</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_online_payment']" position="before">
                <field name="quickbooks_id" string="Quickbooks ID"/>
            </xpath>
        </field>
    </record>

    <!-- Tree/List View -->
    <record id="view_pos_payment_method_tree_inherit_quickbooks" model="ir.ui.view">
        <field name="name">pos.payment.method.tree.inherit.quickbooks</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_online_payment']" position="before">
                <field name="quickbooks_id"/>
            </xpath>
        </field>
    </record>
</odoo>